<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher long-press shortcuts. Each fires a grove:// deep link that the
  NavHost matches to the per-template capture editor, so the user lands
  straight in the editor (Journal) or the title prompt then editor (Quick
  Note). IDs match the built-in templates in DefaultTemplates.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="journal"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_journal"
        android:shortcutShortLabel="@string/shortcut_journal_short"
        android:shortcutLongLabel="@string/shortcut_journal_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="grove://capture/builtin-journal"
            android:targetClass="com.rrajath.grove.MainActivity"
            android:targetPackage="com.rrajath.grove" />
    </shortcut>
    <shortcut
        android:shortcutId="quick_note"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_quick_note"
        android:shortcutShortLabel="@string/shortcut_quick_note_short"
        android:shortcutLongLabel="@string/shortcut_quick_note_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="grove://capture/builtin-quick-note"
            android:targetClass="com.rrajath.grove.MainActivity"
            android:targetPackage="com.rrajath.grove" />
    </shortcut>
</shortcuts>
