<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Fetch the page title for shared URLs so notes read better than a bare link. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".GroveApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Grove">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Grove">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Long-press launcher shortcuts: Journal and Quick Note (capture). -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
            <!-- Share sheet target: text and URLs route into capture (PRD §10) -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
            </intent-filter>
            <!-- grove:// deep links (widget, notification, note shortcuts) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="grove" />
            </intent-filter>
            <!--
              Open .org files: register Grove so it can be set as the default
              handler. Org has no registered MIME type, so we match by extension
              (file managers usually send application/octet-stream or text/*) as
              well as the conventional text/org type. The repeated pathPatterns
              work around Android's greedy `.*` not spanning earlier dots in a
              file name (e.g. "notes.2026.org").
            -->
            <intent-filter android:label="@string/app_name">
                <action android:name="android.intent.action.VIEW" />
                <action android:name="android.intent.action.EDIT" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="text/org" />
                <data android:mimeType="text/x-org" />
                <data android:mimeType="application/octet-stream" />
                <data android:pathPattern=".*\\.org" />
                <data android:pathPattern=".*\\..*\\.org" />
                <data android:pathPattern=".*\\..*\\..*\\.org" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.CaptureWidgetReceiver"
            android:exported="true"
            android:label="Capture">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/capture_widget_info" />
        </receiver>
    </application>

</manifest>