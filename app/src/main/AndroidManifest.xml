<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Fetch the page title for shared URLs so notes read better than a bare link. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".GroveApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Grove">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Grove">
            <!-- Share sheet target: text and URLs route into capture (PRD §10) -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
            </intent-filter>
            <!-- grove:// deep links (widget, notification, note shortcuts) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="grove" />
            </intent-filter>
            <!--
              Open .org files: register Grove so it can be set as the default
              handler. Org has no registered MIME type, so we match by extension
              (file managers usually send application/octet-stream or text/*) as
              well as the conventional text/org type. The repeated pathPatterns
              work around Android's greedy `.*` not spanning earlier dots in a
              file name (e.g. "notes.2026.org").
            -->
            <intent-filter android:label="@string/app_name">
                <action android:name="android.intent.action.VIEW" />
                <action android:name="android.intent.action.EDIT" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="text/org" />
                <data android:mimeType="text/x-org" />
                <data android:mimeType="application/octet-stream" />
                <data android:pathPattern=".*\\.org" />
                <data android:pathPattern=".*\\..*\\.org" />
                <data android:pathPattern=".*\\..*\\..*\\.org" />
            </intent-filter>
        </activity>

        <!-- Launcher icon aliases for "Sync App Icon with Theme" (Settings > Appearance).
             Exactly one of these is enabled at a time via AppIconManager. -->
        <activity-alias
            android:name=".IconDefault"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconLight"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_light"
            android:roundIcon="@mipmap/ic_launcher_light_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconDark"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_dark"
            android:roundIcon="@mipmap/ic_launcher_dark_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconTokyoNight"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_tokyonight"
            android:roundIcon="@mipmap/ic_launcher_tokyonight_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconSynthwave"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_synthwave"
            android:roundIcon="@mipmap/ic_launcher_synthwave_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconDracula"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_dracula"
            android:roundIcon="@mipmap/ic_launcher_dracula_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconCatppuccin"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_catppuccin"
            android:roundIcon="@mipmap/ic_launcher_catppuccin_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconNord"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_nord"
            android:roundIcon="@mipmap/ic_launcher_nord_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <receiver
            android:name=".widget.CaptureWidgetReceiver"
            android:exported="true"
            android:label="Capture">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/capture_widget_info" />
        </receiver>
    
    <!-- Required: set your sentry.io project identifier (DSN) -->
    <meta-data android:name="io.sentry.dsn" android:value="https://22613e1316854dcc4634e34bd7964521@o4504759805476864.ingest.us.sentry.io/4511700837138432" />

    <!-- set up releases -->
    <meta-data android:name="io.sentry.release" android:value="${sentryRelease}" />
    <!-- set up sentry session tracking -->
    <meta-data android:name="io.sentry.session-tracking.timeout-interval-millis" android:value="60000" />
    <!-- enable automatic breadcrumbs for user interactions (clicks, swipes, scrolls) -->
    <meta-data android:name="io.sentry.traces.user-interaction.enable" android:value="true" />
    <!-- enable screenshot for crashes (could contain sensitive/PII data) -->
    <meta-data android:name="io.sentry.attach-screenshot" android:value="true" />
    <!-- enable view hierarchy for crashes -->
    <meta-data android:name="io.sentry.attach-view-hierarchy" android:value="true" />

    <!-- enable the performance API by setting a sample-rate, adjust in production env -->
    <meta-data android:name="io.sentry.traces.sample-rate" android:value="1.0" />
</application>

</manifest>